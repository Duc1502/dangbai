# Website URLs
WEBSITE_1_URL=https://techupdatedaily.com/
WEBSITE_2_URL=https://another-site.com

# Admin Credentials
WEBSITE_1_USERNAME=admin
WEBSITE_1_PASSWORD=password123

WEBSITE_2_USERNAME=admin
WEBSITE_2_PASSWORD=password123

# API Keys
GROQ_API_KEY=gsk_...
STABILITY_API_KEY=sk-...
WORDPRESS_API_TOKEN=your_token_here

# Email (để gửi report)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=your_email@gmail.com

# Other
LOG_LEVEL=INFO
OUTPUT_FORMAT=json
